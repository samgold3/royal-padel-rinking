<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Royal Padel Rinking — Padel indoor sous verrière · Ixelles</title>
<meta name="description" content="12 courts de padel indoor sous la verrière Art Nouveau du Royal Rinking (1910), Chaussée de Waterloo 567, Ixelles. Le padel, dans un monument.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ============ TOKENS ============ */
:root{
  --noir:#080D16;
  --vert-1:#0C1A2E;        /* fond principal — bleu terrain de padel */
  --vert-2:#10233E;        /* panneaux */
  --vert-3:#173456;        /* hover */
  --gold:#C9A35C;
  --gold-light:#E6CD92;
  --gold-deep:#9C7A3C;
  --cream:#EFE9D8;
  --cream-2:#E7E0CC;
  --ink:#17202E;
  --line:rgba(201,163,92,.28);
  --line-soft:rgba(201,163,92,.14);
  --txt:#E9E4D6;
  --txt-dim:rgba(233,228,214,.66);
  --serif:"Cormorant Garamond", Georgia, serif;
  --sans:"Jost", "Segoe UI", sans-serif;
  --max:1180px;
}

/* ============ BASE ============ */
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  font-family:var(--sans);
  font-weight:300;
  background:var(--vert-1);
  color:var(--txt);
  line-height:1.65;
  -webkit-font-smoothing:antialiased;
}
img,svg{display:block;max-width:100%}
a{color:inherit;text-decoration:none}
ul{list-style:none}
:focus-visible{outline:2px solid var(--gold);outline-offset:3px;border-radius:2px}

.wrap{max-width:var(--max);margin:0 auto;padding:0 6vw}
.section{padding:clamp(5rem,10vw,8.5rem) 0}

/* typographie */
.eyebrow{
  font-family:var(--sans);font-weight:500;
  font-size:.74rem;letter-spacing:.26em;text-transform:uppercase;
  color:var(--gold);
}
h1,h2,h3{font-family:var(--serif);font-weight:500;line-height:1.05;letter-spacing:.01em}
h2{font-size:clamp(2.1rem,4.6vw,3.5rem);margin:1rem 0 1.4rem}
h2 em,h1 em{font-style:italic;color:var(--gold-light)}
.lead{font-size:clamp(1.02rem,1.5vw,1.18rem);color:var(--txt-dim);max-width:42rem}
.on-cream .lead{color:rgba(26,36,30,.72)}

/* boutons */
.btn{
  display:inline-flex;align-items:center;gap:.6rem;
  font-family:var(--sans);font-weight:500;font-size:.82rem;
  letter-spacing:.16em;text-transform:uppercase;
  padding:1.05rem 2.1rem;border-radius:2px;
  transition:transform .25s ease, box-shadow .25s ease, background .25s ease, color .25s ease;
  cursor:pointer;border:none;
}
.btn-gold{
  background:linear-gradient(135deg,var(--gold-light),var(--gold) 55%,var(--gold-deep));
  color:#241B0C;
  box-shadow:0 6px 24px rgba(201,163,92,.22);
}
.btn-gold:hover{transform:translateY(-2px);box-shadow:0 10px 30px rgba(201,163,92,.32)}
.btn-ghost{
  background:transparent;color:var(--gold);
  box-shadow:inset 0 0 0 1px var(--line);
}
.btn-ghost:hover{box-shadow:inset 0 0 0 1px var(--gold);transform:translateY(-2px)}

/* filets laiton */
.rule{width:56px;height:1px;background:linear-gradient(90deg,var(--gold),transparent);margin:1.6rem 0}

/* reveal au scroll */
.reveal{opacity:0;transform:translateY(26px);transition:opacity .8s ease,transform .8s ease}
.reveal.in{opacity:1;transform:none}
.d1{transition-delay:.08s}.d2{transition-delay:.16s}.d3{transition-delay:.24s}.d4{transition-delay:.32s}

/* ============ NAV ============ */
.nav{
  position:fixed;inset:0 0 auto 0;z-index:50;
  transition:background .35s ease,border-color .35s ease;
  border-bottom:1px solid transparent;
}
.nav.scrolled{
  background:rgba(8,13,22,.82);
  backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);
  border-bottom-color:var(--line-soft);
}
.nav-inner{
  max-width:var(--max);margin:0 auto;padding:1.1rem 6vw;
  display:flex;align-items:center;justify-content:space-between;gap:2rem;
}
.brand{display:flex;align-items:center;gap:.85rem}
.brand svg{width:34px;height:auto}
.brand-name{
  font-family:var(--sans);font-weight:500;font-size:.8rem;
  letter-spacing:.3em;text-transform:uppercase;color:var(--txt);
}
.brand-name span{color:var(--gold)}
.nav-links{display:flex;align-items:center;gap:2.2rem}
.nav-links a{
  font-size:.78rem;font-weight:400;letter-spacing:.18em;text-transform:uppercase;
  color:var(--txt-dim);transition:color .25s ease;
}
.nav-links a:hover{color:var(--gold-light)}
.nav .btn{padding:.7rem 1.4rem;font-size:.72rem}
.burger{display:none;background:none;border:none;cursor:pointer;padding:.4rem}
.burger span{display:block;width:24px;height:1.5px;background:var(--gold);margin:6px 0;transition:.3s}

/* menu mobile */
.mobile-menu{
  position:fixed;inset:0;z-index:49;background:rgba(8,13,22,.97);
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2.2rem;
  opacity:0;pointer-events:none;transition:opacity .35s ease;
}
.mobile-menu.open{opacity:1;pointer-events:auto}
.mobile-menu a{
  font-family:var(--serif);font-size:1.9rem;color:var(--txt);
}
.mobile-menu a:hover{color:var(--gold-light)}

/* ============ HERO ============ */
.hero{
  min-height:100svh;display:flex;flex-direction:column;
  align-items:center;justify-content:center;text-align:center;
  position:relative;overflow:hidden;
  padding:7rem 6vw 4rem;
  background:
    radial-gradient(ellipse 70% 45% at 50% 0%, rgba(201,163,92,.10), transparent 65%),
    var(--vert-1);
}
.verriere{width:min(760px,92vw);margin-bottom:.5rem}
.verriere path,.verriere circle,.verriere line{
  fill:none;stroke:var(--gold);stroke-width:1.4;
  stroke-linecap:round;
}
.verriere .soft{stroke:var(--line)}
.verriere .fin{fill:var(--gold);stroke:none}
/* dessin animé de la verrière */
.verriere .draw{stroke-dasharray:1;stroke-dashoffset:1;animation:draw 2.2s ease forwards}
.verriere .draw:nth-child(2){animation-delay:.15s}
.verriere .draw:nth-child(3){animation-delay:.3s}
.verriere .draw:nth-child(4){animation-delay:.45s}
.verriere .ribs line{stroke-dasharray:1;stroke-dashoffset:1;animation:draw 1.4s ease forwards;animation-delay:.7s}
.verriere .ribs line:nth-child(odd){animation-delay:.9s}
.verriere .orn{stroke-dasharray:1;stroke-dashoffset:1;animation:draw 1.6s ease 1.3s forwards}
@keyframes draw{to{stroke-dashoffset:0}}

.hero .eyebrow{margin-bottom:1.2rem}
.hero h1{
  font-size:clamp(2.9rem,8.4vw,6.4rem);
  font-weight:500;color:var(--txt);
}
.hero h1 .thin{font-weight:400;font-style:italic;color:var(--gold-light)}
.slogan{
  display:flex;align-items:baseline;justify-content:center;gap:.55rem;
  margin-top:1.4rem;
  font-family:var(--serif);font-style:italic;
  font-size:clamp(1.25rem,2.4vw,1.7rem);color:var(--txt-dim);
}
/* la balle qui rebondit — signature du slogan */
.ball-stage{position:relative;width:14px;height:14px}
.ball{
  position:absolute;bottom:2px;left:0;width:12px;height:12px;border-radius:50%;
  background:radial-gradient(circle at 35% 30%, var(--gold-light), var(--gold) 60%, var(--gold-deep));
  animation:bounce 1.7s cubic-bezier(.5,.05,.5,1) infinite;
  transform-origin:center bottom;
}
.ball-shadow{
  position:absolute;bottom:0;left:1px;width:10px;height:3px;border-radius:50%;
  background:rgba(0,0,0,.45);filter:blur(1px);
  animation:shadow 1.7s cubic-bezier(.5,.05,.5,1) infinite;
}
@keyframes bounce{
  0%,100%{transform:translateY(0) scale(1.18,.8)}
  12%{transform:translateY(-6px) scale(1,1)}
  50%{transform:translateY(-30px) scale(.96,1.04)}
  88%{transform:translateY(-6px) scale(1,1)}
}
@keyframes shadow{
  0%,100%{transform:scale(1.25);opacity:.5}
  50%{transform:scale(.55);opacity:.18}
}
.hero-sub{margin:1.6rem auto 2.6rem;max-width:34rem;color:var(--txt-dim);font-size:1.05rem}
.hero-cta{display:flex;gap:1rem;flex-wrap:wrap;justify-content:center}
.scroll-hint{
  position:absolute;bottom:2.2rem;left:50%;transform:translateX(-50%);
  font-size:.68rem;letter-spacing:.3em;text-transform:uppercase;color:var(--txt-dim);
  display:flex;flex-direction:column;align-items:center;gap:.6rem;
}
.scroll-hint::after{
  content:"";width:1px;height:42px;
  background:linear-gradient(var(--gold),transparent);
  animation:drip 2.2s ease infinite;
}
@keyframes drip{0%{transform:scaleY(0);transform-origin:top}55%{transform:scaleY(1);transform-origin:top}56%{transform-origin:bottom}100%{transform:scaleY(0);transform-origin:bottom}}

/* ============ LE LIEU ============ */
.lieu-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(2.5rem,6vw,5.5rem);align-items:center}
.lieu-visual{
  position:relative;border:1px solid var(--line-soft);border-radius:3px;
  background:
    radial-gradient(ellipse 80% 60% at 50% 0%, rgba(201,163,92,.13), transparent 70%),
    var(--vert-2);
  padding:clamp(2rem,4vw,3.2rem);
}
.lieu-visual svg{width:100%;height:auto}
.lieu-visual .cap{
  margin-top:1.4rem;text-align:center;
  font-family:var(--serif);font-style:italic;font-size:1.02rem;color:var(--txt-dim);
}
.drop{
  font-family:var(--serif);font-size:3.4rem;line-height:.8;
  float:left;margin:.35rem .65rem 0 0;color:var(--gold-light);
}

/* bandeau de faits */
.facts{
  border-top:1px solid var(--line-soft);border-bottom:1px solid var(--line-soft);
  display:grid;grid-template-columns:repeat(4,1fr);
}
.fact{
  padding:2.4rem 1.6rem;text-align:center;
  border-left:1px solid var(--line-soft);
}
.fact:first-child{border-left:none}
.fact b{
  display:block;font-family:var(--serif);font-weight:500;
  font-size:clamp(1.7rem,2.6vw,2.3rem);color:var(--gold-light);margin-bottom:.4rem;
}
.fact span{font-size:.74rem;letter-spacing:.2em;text-transform:uppercase;color:var(--txt-dim)}

/* ============ TERRAINS ============ */
.terrains{background:var(--noir)}
.stats{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line-soft);border:1px solid var(--line-soft);margin:3.4rem 0;border-radius:3px;overflow:hidden}
.stat{background:var(--vert-2);padding:2.6rem 2rem;text-align:center;transition:background .3s ease}
.stat:hover{background:var(--vert-3)}
.stat b{display:block;font-family:var(--serif);font-weight:500;font-size:clamp(2.4rem,4vw,3.4rem);color:var(--gold-light)}
.stat span{font-size:.76rem;letter-spacing:.2em;text-transform:uppercase;color:var(--txt-dim)}
.feat-list{display:grid;grid-template-columns:repeat(3,1fr);gap:2.6rem;margin-top:1rem}
.feat h3{font-size:1.45rem;margin:.9rem 0 .5rem}
.feat p{color:var(--txt-dim);font-size:.96rem}
.feat .ico{width:40px;height:40px}
.feat .ico *{fill:none;stroke:var(--gold);stroke-width:1.4;stroke-linecap:round;stroke-linejoin:round}

/* ============ BAR (section claire) ============ */
.bar{background:var(--cream);color:var(--ink)}
.bar .eyebrow{color:var(--gold-deep)}
.bar h2{color:var(--ink)}
.bar h2 em{color:var(--gold-deep)}
.bar-grid{display:grid;grid-template-columns:.95fr 1.05fr;gap:clamp(2.5rem,6vw,5.5rem);align-items:center}
.bar-feats{margin-top:2.4rem;display:grid;gap:1.5rem}
.bar-feat{display:flex;gap:1.2rem;align-items:flex-start}
.bar-feat .ico{flex:0 0 34px;width:34px;height:34px}
.bar-feat .ico *{fill:none;stroke:var(--gold-deep);stroke-width:1.4;stroke-linecap:round;stroke-linejoin:round}
.bar-feat b{display:block;font-family:var(--serif);font-weight:600;font-size:1.18rem;margin-bottom:.15rem}
.bar-feat p{font-size:.94rem;color:rgba(26,36,30,.7)}
.menu-card{
  background:var(--cream-2);border:1px solid rgba(156,122,60,.35);border-radius:3px;
  padding:clamp(1.8rem,3.5vw,2.8rem);
  box-shadow:0 24px 60px rgba(26,36,30,.10);
}
.menu-card h3{
  text-align:center;font-size:1.5rem;font-weight:600;
  padding-bottom:1.1rem;margin-bottom:1.1rem;
  border-bottom:1px solid rgba(156,122,60,.3);
}
.menu-line{display:flex;justify-content:space-between;align-items:baseline;gap:1rem;padding:.55rem 0;font-size:.97rem}
.menu-line i{font-style:normal;flex:1;border-bottom:1px dotted rgba(156,122,60,.45);transform:translateY(-4px)}
.menu-line em{font-family:var(--serif);font-style:italic;color:var(--gold-deep)}
.menu-note{margin-top:1.2rem;text-align:center;font-size:.8rem;letter-spacing:.08em;color:rgba(26,36,30,.55)}

/* ============ OFFRES ============ */
.offres-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.4rem;margin-top:3rem}
.offre{
  background:var(--vert-2);border:1px solid var(--line-soft);border-radius:3px;
  padding:2.2rem 1.8rem;display:flex;flex-direction:column;
  transition:transform .3s ease,border-color .3s ease,background .3s ease;
}
.offre:hover{transform:translateY(-5px);border-color:var(--gold);background:var(--vert-3)}
.offre .num{font-size:.72rem;letter-spacing:.24em;color:var(--gold);text-transform:uppercase}
.offre h3{font-size:1.55rem;margin:.7rem 0 .9rem}
.offre p{font-size:.92rem;color:var(--txt-dim);margin-bottom:1.2rem}
.offre ul{margin-bottom:1.8rem;display:grid;gap:.5rem}
.offre li{font-size:.88rem;color:var(--txt-dim);padding-left:1.1rem;position:relative}
.offre li::before{content:"·";position:absolute;left:0;color:var(--gold);font-weight:600}
.offre a{
  margin-top:auto;font-size:.76rem;letter-spacing:.18em;text-transform:uppercase;
  color:var(--gold);display:inline-flex;align-items:center;gap:.5rem;
  transition:gap .25s ease,color .25s ease;
}
.offre a:hover{gap:.9rem;color:var(--gold-light)}

/* ============ RÉSERVATION ============ */
.resa{
  text-align:center;position:relative;overflow:hidden;
  background:
    radial-gradient(ellipse 60% 80% at 50% 50%, rgba(201,163,92,.14), transparent 70%),
    var(--noir);
  border-top:1px solid var(--line-soft);border-bottom:1px solid var(--line-soft);
}
.resa h2{font-size:clamp(2.4rem,5.5vw,4.2rem)}
.resa .lead{margin:0 auto 2.6rem}

/* ============ CONTACT ============ */
.contact{background:var(--cream);color:var(--ink)}
.contact .eyebrow{color:var(--gold-deep)}
.contact h2{color:var(--ink)}
.contact-grid{display:grid;grid-template-columns:.9fr 1.1fr;gap:clamp(2.5rem,6vw,5rem);margin-top:1rem}
.coord{display:grid;gap:1.6rem;align-content:start}
.coord-item b{
  display:block;font-size:.72rem;letter-spacing:.22em;text-transform:uppercase;
  color:var(--gold-deep);margin-bottom:.3rem;font-weight:500;
}
.coord-item p{font-size:1.02rem}
.coord-item a{border-bottom:1px solid rgba(156,122,60,.4);transition:border-color .25s,color .25s}
.coord-item a:hover{color:var(--gold-deep);border-color:var(--gold-deep)}
.form{display:grid;gap:1.1rem}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:1.1rem}
.field label{
  display:block;font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;
  color:rgba(26,36,30,.6);margin-bottom:.45rem;font-weight:500;
}
.field input,.field textarea{
  width:100%;background:#fff;color:var(--ink);
  border:1px solid rgba(156,122,60,.35);border-radius:2px;
  padding:.95rem 1.05rem;font-family:var(--sans);font-size:.96rem;
  transition:border-color .25s ease,box-shadow .25s ease;
}
.field input:focus,.field textarea:focus{
  outline:none;border-color:var(--gold-deep);
  box-shadow:0 0 0 3px rgba(201,163,92,.18);
}
.field textarea{min-height:130px;resize:vertical}
.form-ok{
  display:none;padding:1.1rem 1.3rem;border:1px solid var(--gold-deep);
  border-radius:2px;background:rgba(201,163,92,.12);font-size:.95rem;
}
.form-ok.show{display:block}

/* ============ FOOTER ============ */
.footer{background:var(--noir);padding:4rem 0 2.5rem;border-top:1px solid var(--line-soft)}
.footer-inner{display:flex;flex-direction:column;align-items:center;gap:1.6rem;text-align:center}
.footer .brand-name{font-size:.74rem}
.footer-nav{display:flex;gap:2rem;flex-wrap:wrap;justify-content:center}
.footer-nav a{font-size:.74rem;letter-spacing:.16em;text-transform:uppercase;color:var(--txt-dim);transition:color .25s}
.footer-nav a:hover{color:var(--gold-light)}
.footer small{font-size:.74rem;color:rgba(233,228,214,.4);letter-spacing:.04em}

/* ============ RESPONSIVE ============ */
@media (max-width:980px){
  .lieu-grid,.bar-grid,.contact-grid{grid-template-columns:1fr}
  .offres-grid{grid-template-columns:repeat(2,1fr)}
  .feat-list{grid-template-columns:1fr;gap:2rem}
  .facts{grid-template-columns:repeat(2,1fr)}
  .fact:nth-child(3){border-left:none}
  .fact{border-top:1px solid var(--line-soft)}
  .fact:nth-child(-n+2){border-top:none}
}
@media (max-width:720px){
  .nav-links{display:none}
  .burger{display:block}
  .offres-grid{grid-template-columns:1fr}
  .stats{grid-template-columns:1fr}
  .form-row{grid-template-columns:1fr}
  .scroll-hint{display:none}
}

/* ============ REDUCED MOTION ============ */
@media (prefers-reduced-motion:reduce){
  html{scroll-behavior:auto}
  .ball,.ball-shadow,.scroll-hint::after{animation:none}
  .verriere .draw,.verriere .ribs line,.verriere .orn{animation:none;stroke-dashoffset:0}
  .reveal{opacity:1;transform:none;transition:none}
  .btn,.offre,.stat{transition:none}
}
</style>
</head>
<body>

<!-- ====== ÉCRAN MOT DE PASSE (privé) ====== -->
<div id="rpr-gate" style="position:fixed;inset:0;z-index:9999;background:#0C1A2E;display:flex;align-items:center;justify-content:center;padding:24px;font-family:'Jost','Segoe UI',sans-serif">
  <div style="width:100%;max-width:380px;text-align:center;color:#EFE9D8">
    <div style="font-family:'Cormorant Garamond',Georgia,serif;font-size:13px;letter-spacing:.34em;text-transform:uppercase;color:#C9A35C">Accès privé</div>
    <h1 style="font-family:'Cormorant Garamond',Georgia,serif;font-weight:500;font-size:38px;line-height:1.1;margin:14px 0 6px;color:#EFE9D8">Royal Padel Rinking</h1>
    <p style="color:rgba(233,228,214,.66);font-size:14px;margin:0 0 26px">Ce site est privé. Entrez le code d'accès pour le consulter.</p>
    <input id="rpr-pass" type="password" placeholder="Code d'accès" autocomplete="off"
      style="width:100%;padding:14px 16px;border:1px solid rgba(201,163,92,.4);background:#10233E;color:#EFE9D8;border-radius:4px;font-size:16px;font-family:inherit;outline:none;text-align:center;letter-spacing:.1em">
    <button id="rpr-btn"
      style="width:100%;margin-top:12px;padding:14px;border:none;background:#C9A35C;color:#0C1A2E;border-radius:4px;font-size:14px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;cursor:pointer;font-family:inherit">Entrer</button>
    <p id="rpr-err" style="color:#E08A7A;font-size:13px;height:18px;margin:14px 0 0;visibility:hidden">Code incorrect, réessayez.</p>
  </div>
</div>
<script>
(function(){
  /* ====== CHANGE TON CODE ICI ====== */
  var MOT_DE_PASSE = "rinking2026";
  /* ================================= */
  var gate=document.getElementById('rpr-gate'),
      inp=document.getElementById('rpr-pass'),
      btn=document.getElementById('rpr-btn'),
      err=document.getElementById('rpr-err');
  document.body.style.overflow='hidden';
  function tryOpen(){
    if(inp.value===MOT_DE_PASSE){
      gate.style.display='none';
      document.body.style.overflow='';
    }else{
      err.style.visibility='visible';
      inp.value='';inp.focus();
    }
  }
  btn.addEventListener('click',tryOpen);
  inp.addEventListener('keydown',function(e){if(e.key==='Enter')tryOpen();});
  setTimeout(function(){inp.focus();},100);
})();
</script>
<!-- ====== FIN ÉCRAN MOT DE PASSE ====== -->

<!-- ===================== NAV ===================== -->
<header class="nav" id="nav">
  <div class="nav-inner">
    <a href="#top" class="brand" aria-label="Royal Padel Rinking — accueil">
      <svg viewBox="0 0 60 34" aria-hidden="true">
        <path d="M4 32 A26 26 0 0 1 56 32" fill="none" stroke="#C9A35C" stroke-width="2"/>
        <line x1="30" y1="32" x2="30" y2="6" stroke="#C9A35C" stroke-width="1.4"/>
